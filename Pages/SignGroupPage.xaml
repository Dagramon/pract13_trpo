<Page x:Class="pract12_trpo.Pages.SignGroupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pract12_trpo.Pages"
      xmlns:validators="clr-namespace:pract12_trpo.Classes.Validations"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SignGroupPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0"
                    Margin="5">
            <Button HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Grid.Column="0"
                Click="go_back">
                Назад
            </Button>
            <Label FontSize="20">Информация о пользователе</Label>
            <TextBlock Text="{Binding userInterestGroup.User.Login}"></TextBlock>
            <TextBlock Text="{Binding userInterestGroup.User.UserName}"></TextBlock>
            <TextBlock Text="{Binding userInterestGroup.User.Email}"></TextBlock>
            <TextBlock Text="{Binding userInterestGroup.User.CreatedAt, StringFormat={}Добавлен: {0}}"></TextBlock>
            <TextBlock Text="{Binding userInterestGroup.User.Role.Title}"></TextBlock>
            <StackPanel Orientation="Horizontal" Margin="5">
                <CheckBox IsChecked="{Binding userInterestGroup.IsModerator}"></CheckBox>
                <Label>Должен быть модератором группы?</Label>
            </StackPanel>
            <StackPanel>
                <Label>Присоединился:</Label>
                <DatePicker x:Name="joinedPicker">
                    <DatePicker.SelectedDate>
                        <Binding Path="userInterestGroup.JoinedAt"
                                 UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules>
                                <validators:DateValidation/>
                            </Binding.ValidationRules>
                        </Binding>
                    </DatePicker.SelectedDate>
                </DatePicker>
                <ItemsControl Style="{StaticResource ErrorText}"
                              ItemsSource="{Binding ElementName=joinedPicker, Path=(Validation.Errors)}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ErrorContent}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            
            <Button Style="{StaticResource GreenButton}"
                    Click="sign">Записать в группу интересов</Button>
        </StackPanel>
        <ListView Grid.Column="1"
                  ItemsSource="{Binding service.InterestGroups}"
                  SelectedItem="{Binding userInterestGroup.InterestGroup}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding Title}"></TextBlock>
                        <TextBlock Text="{Binding Description}"></TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
