<Page x:Class="pract12_trpo.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pract12_trpo.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
            <Button Click="AddNavigate" Style="{StaticResource GreenButton}">Добавить</Button>
            <Button Click="Remove" Style="{StaticResource RedButton}">Удалить</Button>
            <Button Click="RolesNavigate">Роли</Button>
            <Button Click="GoInterestGroup_Click">Группы интересов</Button>
            <Button Click="GoProfile_Click">Профиль выбранного пользователя</Button>
            <Button Click="GoSignGroup_Click">Записать в группу интересов</Button>
            <Label>Список интересов:</Label>
            <ListView ItemsSource="{Binding currentUserGroups}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical">
                            <TextBlock>
                                <Run Text="Группа: "/>
                                <Run Text="{Binding InterestGroup.Title}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Дата вступления: "/>
                                <Run Text="{Binding JoinedAt, StringFormat={}{0:dd.MM.yyyy}}"/>
                            </TextBlock>
                            <TextBlock>Модератор?</TextBlock>
                            <CheckBox IsEnabled="False"
                                      IsChecked="{Binding IsModerator}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
        <ListView Grid.Column="1"
                  ItemsSource="{Binding service.Users}"
                  MouseDoubleClick="Edit"
                  SelectedItem="{Binding user}"
                  Width="auto"
                  HorizontalAlignment="Center"
                  SelectionChanged="ChangedUser">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black"
                            BorderThickness="3"
                            Padding="15"
                            CornerRadius="5"
                            Width="250">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ID: "/>
                                <TextBlock Text="{Binding Id}"></TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Логин: "/>
                                <TextBlock Text="{Binding Login}"></TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Имя пользователя: "/>
                                <TextBlock Text="{Binding UserName}"></TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Почта: "/>
                                <TextBlock Text="{Binding Email}"></TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Пароль: "/>
                                <TextBlock Text="{Binding Password}"></TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Дата создания: "/>
                                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy}}"></TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Группа: "/>
                                <TextBlock Text="{Binding Role.Title}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
