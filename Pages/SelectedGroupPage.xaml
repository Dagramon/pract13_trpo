<Page x:Class="pract12_trpo.Pages.SelectedGroupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pract12_trpo.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SelectedGroupPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Button Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top" Click="go_back">Назад</Button>
        <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="profilePanel">
            <Image Source="/Images/Error.png">
            </Image>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Ссылка на аватар: "/>
                <TextBlock Text="{Binding AvatarUrl, UpdateSourceTrigger=PropertyChanged, TargetNullValue='Нет'}"></TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Номер телефона: "/>
                <TextBlock Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged, TargetNullValue='Нет'}"></TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Дата рождения: "/>
                <TextBlock Text="{Binding Birthday, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:dd.MM.yyyy}, TargetNullValue='Нет'}"></TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Описание: "/>
                <TextBlock Text="{Binding Bio, UpdateSourceTrigger=PropertyChanged, TargetNullValue='Нет'}"></TextBlock>
            </StackPanel>
        </StackPanel>
        <ListView Grid.Column="1"
                  ItemsSource="{Binding group.UserInterestGroups}"
                  SelectedItem="{Binding userInterestGroup}"
                  SelectionChanged="CheckProfile">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{Binding User.UserName}"></TextBlock>
                            <TextBlock Text="{Binding JoinedAt, StringFormat={}{0:dd.MM.yyyy}}"></TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <TextBlock>Модератор?</TextBlock>
                            <CheckBox IsEnabled="False" IsChecked="{Binding IsModerator}"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
